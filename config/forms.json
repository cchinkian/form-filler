{
  "_shared_fields": {
    "client_name":  {"name": "client_name",  "source": "data",       "font_size": 10},
    "ic_number":    {"name": "ic_number",    "source": "data",       "font_size": 10, "format": "ic_dashed"},
    "phone":        {"name": "phone",        "source": "data",       "font_size": 10},
    "email":        {"name": "email",        "source": "data",       "font_size": 10},
    "address_line1":{"name": "address_line1","source": "data",       "font_size": 10},
    "address_line2":{"name": "address_line2","source": "data",       "font_size": 10},
    "city":         {"name": "city",         "source": "data",       "font_size": 10},
    "state":        {"name": "state",        "source": "data",       "font_size": 10},
    "postcode":     {"name": "postcode",     "source": "data",       "font_size": 10},

    "date":         {"name": "date",         "source": "session",    "session_key": "date",      "font_size": 10},
    "rm_branch":    {"name": "rm_branch",    "source": "session",    "session_key": "rm_branch", "font_size": 9},
    "staff_rm_code":{"name": "staff_rm_code","source": "session",    "session_key": "staff_rm_code", "font_size": 9},

    "staff_name":   {"name": "staff_name",   "source": "staff_profile", "profile_key": "staff_name", "font_size": 9},
    "staff_ic":     {"name": "staff_ic",     "source": "staff_profile", "profile_key": "staff_ic", "font_size": 9, "format": "ic_dashed"},
    "staff_id":     {"name": "staff_id",     "source": "staff_profile", "profile_key": "staff_id",  "font_size": 9},
    "fimm_id":      {"name": "fimm_id",      "source": "staff_profile", "profile_key": "fimm_id",   "font_size": 9},
    "ippc_id":      {"name": "ippc_id",      "source": "staff_profile", "profile_key": "ippc_id",   "font_size": 9},
    "staff_position":{"name": "staff_position","source": "staff_profile", "profile_key": "staff_position", "font_size": 9},
    "rm_name":      {"name": "rm_name",      "source": "staff_profile", "profile_key": "rm_name",   "font_size": 9},

    "currency_label": {"name": "currency_label", "source": "fixed", "value": "MYR", "font_size": 10}
  },

  "_TEMPLATE": {
    "_usage": [
      "Copy this block, rename the key (e.g. 'kyc_single'), fill coordinates.",
      "Use 'shared' to reference _shared_fields — only x, y, page needed.",
      "Use 'name' + full field def for form-specific fields.",
      "Each form folder should have exactly one PDF; the PDF filename can be anything.",
      "Source choices in Mapping Editor follow clients.xlsx sheet names, plus Session Input, Fixed Text, Auto Date."
    ],
    "name": "Form Display Name",
    "template_subfolder": "subfolder_inside_forms",
    "template_hash": "",
    "fields": [
      {"shared": "client_name", "page": 1, "x": 0, "y": 0},
      {"shared": "ic_number",   "page": 1, "x": 0, "y": 0},
      {"shared": "date",        "page": 1, "x": 0, "y": 0},
      {"shared": "rm_branch",   "page": 1, "x": 0, "y": 0},
      {"shared": "staff_rm_code","page": 1, "x": 0, "y": 0},
      {"shared": "staff_name",  "page": 1, "x": 0, "y": 0},
      {"shared": "staff_id",    "page": 1, "x": 0, "y": 0},
      {"shared": "fimm_id",     "page": 1, "x": 0, "y": 0,
       "_comment": "Only include if THIS form has an FIMM ID slot"},
      {
        "_comment": "Form-specific field (not shared):",
        "name": "fd_amount", "page": 1, "x": 0, "y": 0,
        "source": "data", "format": "currency_2_decimals", "required": true
      },
      {
        "_comment": "Fixed value (never changes):",
        "name": "currency", "page": 1, "x": 0, "y": 0,
        "source": "fixed", "value": "MYR"
      }
    ]
  }
}
